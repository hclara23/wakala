<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ site.name }} | Thank You</title>
    <meta name="description" content="Thanks for reaching out to {{ site.name }}.">
    <meta name="robots" content="noindex, nofollow">
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;600;800&family=Teko:wght@400;600;700&display=swap"
        rel="stylesheet">
</head>

<body>
    <main class="content-container thank-you-page">
        <section class="booking-panel thank-you-panel">
            <h1 class="thank-you-title">Thank you</h1>
            <p class="thank-you-copy">
                We received your request and will contact you shortly to confirm details and next steps.
            </p>
            <p class="thank-you-copy">
                If you need us sooner, call <a href="tel:{{ site.phone }}">{{ site.phone_display }}</a> or email
                <a href="mailto:{{ site.email }}">{{ site.email }}</a>.
            </p>
            {% if site.calendar_public_url %}
            <p class="thank-you-copy">
                View current availability on our <a href="{{ site.calendar_public_url }}" target="_blank" rel="noopener">booking calendar</a>.
            </p>
            {% endif %}
            <div class="cta-wrapper thank-you-actions">
                <a class="simulated-link" href="/">Return to home &rarr;</a>
            </div>
        </section>
    </main>
</body>

</html>
