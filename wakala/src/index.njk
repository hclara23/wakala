<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ site.name }} | Roll-Offs & More</title>
    <meta name="description" content="{{ site.description }}">
    <meta name="robots" content="index,follow">
    <meta name="theme-color" content="#050505">
    <link rel="canonical" href="{{ site.url }}/">
    <meta property="og:title" content="{{ site.name }} | Roll-Offs & More">
    <meta property="og:description" content="{{ site.description }}">
    <meta property="og:site_name" content="{{ site.name }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ site.url }}/">
    {% if site.locale %}
    <meta property="og:locale" content="{{ site.locale }}">
    {% endif %}
    {% if site.og_image %}
    <meta property="og:image" content="{{ site.og_image }}">
    {% endif %}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ site.name }} | Roll-Offs & More">
    <meta name="twitter:description" content="{{ site.description }}">
    {% if site.og_image %}
    <meta name="twitter:image" content="{{ site.og_image }}">
    {% endif %}
    <link rel="sitemap" type="application/xml" href="{{ site.url }}/sitemap.xml">
    <link rel="stylesheet" href="style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <!-- Teko for heavy industrial headers, Manrope for clean legible body -->
    <link
        href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;600;800&family=Teko:wght@400;600;700&display=swap"
        rel="stylesheet">
    <!-- Netlify Identity Widget for Decap CMS Login -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" defer></script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "{{ site.name }}",
      "url": "{{ site.url }}/",
      "telephone": "{{ site.phone }}",
      "email": "{{ site.email }}",
      "areaServed": "{{ site.area_served }}",
      "description": "{{ site.description }}",
      "sameAs": [
        "{{ site.google_business_url }}"
      ]
    }
    </script>
</head>

<body>
    <a class="skip-link" href="#main-content">Skip to content</a>

    <div class="bg-container">
        <!-- 0: Intro -->
        <div class="bg-image bg-0"></div>
        <!-- 1: Dumpsters -->
        <div class="bg-image bg-1"></div>
        <!-- 2: Trailers -->
        <div class="bg-image bg-2"></div>
        <!-- 3: Pressure Washing -->
        <div class="bg-image bg-3"></div>
        <!-- 4: Handyman -->
        <div class="bg-image bg-4"></div>
        <!-- 5: Yard Cleanups -->
        <div class="bg-image bg-5"></div>
        <!-- 6: Remodels -->
        <div class="bg-image bg-6"></div>
        <!-- 7: Payment / Outro -->
        <div class="bg-image bg-7"></div>

        <div class="bg-overlay-noise"></div>
    </div>

    <!-- Fixed Header Contact -->
    <header class="fixed-nav" role="banner">
        <div class="nav-brand">{{ site.name }}</div>
        <nav class="nav-contact" aria-label="Contact">
            <a href="tel:{{ site.phone }}">{{ site.phone_display }}</a>
            <a href="mailto:{{ site.email }}">{{ site.email }}</a>
        </nav>
    </header>

    <main id="main-content" class="content-container">
        <!-- INTRO -->
        <section class="story-section section-0" data-bg="bg-0">
            <div class="text-block intro full-width">
                <img class="hero-logo" src="{{ site.logo }}" alt="{{ site.name }} logo" width="320" height="320" decoding="async" loading="eager">
                <h1>{{ siteContent.intro.title }}<br><span class="accent-text">{{ siteContent.intro.accent }}</span></h1>
                <p class="subtitle">{{ siteContent.intro.subtitle }}</p>
                <div class="scroll-indicator">
                    <span>SCROLL TO EXPLORE</span>
                    <div class="line"></div>
                </div>
            </div>
        </section>

        {% for service in siteContent.services %}
        {% set index = loop.index %}
        {% set alignment = "right" if index % 2 != 0 else "left border-accent" %}
        
        <!-- SERVICE {{ index }} -->
        <section class="story-section section-{{ index }}" data-bg="bg-{{ index }}">
            <div class="text-block {{ alignment }} solid-panel">
                <div class="panel-header">SERVICE 0{{ index }}</div>
                <h2>{{ service.name }}</h2>
                <p>{{ service.description }}</p>
                <ul class="feature-list">
                    {% for feature in service.features %}
                    <li>{{ feature }}</li>
                    {% endfor %}
                </ul>
                <div class="cta-wrapper"><a class="simulated-link" href="#booking">REQUEST QUOTE &rarr;</a></div>
            </div>
        </section>
        {% endfor %}

        {% if site.calendar_embed_url %}
        <section class="story-section section-calendar" data-bg="bg-7">
            <div class="text-block left solid-panel border-accent calendar-panel">
                <div class="panel-header">AVAILABILITY</div>
                <h2>{{ siteContent.calendar.title }}</h2>
                <p>{{ siteContent.calendar.subtitle }}</p>
                <div class="calendar-embed">
                    <iframe
                        title="Wakala availability calendar"
                        src="{{ site.calendar_embed_url }}"
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        frameborder="0"
                        scrolling="no"></iframe>
                </div>
                <div class="cta-wrapper">
                    <a class="simulated-link" href="{{ site.calendar_public_url }}" target="_blank" rel="noopener">Open Calendar &rarr;</a>
                </div>
            </div>
        </section>
        {% endif %}

        <section class="story-section section-blog" data-bg="bg-7">
            <div class="text-block right solid-panel">
                <div class="panel-header">BLOG</div>
                <h2>{{ siteContent.blog.title }}</h2>
                <p>{{ siteContent.blog.subtitle }}</p>
                {% set posts = collections.blog | reverse | slice(0, 3) %}
                {% if posts.length %}
                <div class="blog-grid">
                    {% for post in posts %}
                    <article class="blog-card">
                        {% if post.data.hero_image %}
                        <div class="blog-card-image">
                            <img src="{{ post.data.hero_image }}" alt="{{ post.data.title }}" loading="lazy">
                        </div>
                        {% endif %}
                        <div class="blog-card-body">
                            <h3>{{ post.data.title }}</h3>
                            <p>{{ post.data.excerpt }}</p>
                            <a class="simulated-link" href="{{ post.url }}">Read More &rarr;</a>
                        </div>
                    </article>
                    {% endfor %}
                </div>
                {% else %}
                <p>No posts yet. Check back soon.</p>
                {% endif %}
                <div class="cta-wrapper">
                    <a class="simulated-link" href="/blog/">View All Posts &rarr;</a>
                </div>
            </div>
        </section>

        <!-- Booking & Payment Panel -->
        <section id="booking" class="story-section section-7 footer-booking" data-bg="bg-7">
            <div class="text-block center booking-panel">
                <h2>{{ siteContent.booking.title }}</h2>
                <p>{{ siteContent.booking.subtitle }}</p>

                <form class="payment-form" id="bookingForm" name="booking" method="POST" data-netlify="true"
                    netlify-honeypot="bot-field" action="/thank-you/">
                    <input type="hidden" name="form-name" value="booking">
                    <p class="sr-only">
                        <label for="bot-field">Don't fill this out if you're human</label>
                        <input id="bot-field" name="bot-field" type="text">
                    </p>
                    <div class="form-row">
                        <label class="sr-only" for="fullName">Full Name</label>
                        <input id="fullName" name="fullName" type="text" placeholder="Full Name" autocomplete="name" required>
                        <label class="sr-only" for="phone">Phone Number</label>
                        <input id="phone" name="phone" type="tel" placeholder="Phone Number" autocomplete="tel" required>
                    </div>
                    <div class="form-row">
                        <label class="sr-only" for="email">Email Address</label>
                        <input id="email" name="email" type="email" placeholder="Email Address" autocomplete="email">
                    </div>
                    <div class="form-row">
                        <label class="sr-only" for="service">Select a Service</label>
                        <select id="service" name="service" required>
                            <option value="">Select a Service</option>
                            <option value="dumpster">15-Yard Dumpster Rental</option>
                            <option value="dumpster20">20-Yard Dumpster Rental</option>
                            <option value="trailer">Trailer Rental</option>
                            <option value="pressure">Pressure Washing</option>
                            <option value="handyman">Handyman Services</option>
                            <option value="yard">Yard Clean-Up</option>
                            <option value="remodel">Small Remodel</option>
                        </select>
                    </div>
                    <div class="form-row">
                        <label class="sr-only" for="details">Project Details</label>
                        <textarea id="details" name="details" rows="4"
                            placeholder="Project details, preferred dates, or questions"></textarea>
                    </div>
                    <button type="submit" class="pay-btn">REQUEST QUOTE</button>
                    <p class="form-note">We will confirm availability and send a secure payment link.</p>
                </form>
                <div class="payment-actions">
                    <button type="button" class="pay-btn stripe-checkout"
                        data-item="{{ siteContent.booking.payment_item }}">{{ siteContent.booking.payment_cta }}</button>
                    <p class="form-note">{{ siteContent.booking.payment_note }}</p>
                    <p class="payment-error" role="alert" aria-live="polite"></p>
                </div>
            </div>
        </section>
        <footer class="site-footer">
            <div class="footer-inner">
                <div class="footer-brand">{{ site.name }}</div>
                <div class="footer-meta">Serving {{ site.area_served }}</div>
                <div class="footer-contact">
                    <a href="tel:{{ site.phone }}">{{ site.phone_display }}</a>
                    <a href="mailto:{{ site.email }}">{{ site.email }}</a>
                    <a href="/admin/">Admin Login</a>
                </div>
            </div>
        </footer>
    </main>

    <!-- GSAP & ScrollTrigger -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" defer></script>
    <script src="script.js" defer></script>
</body>

</html>
