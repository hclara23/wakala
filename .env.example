# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public base URL where this app is hosted.
# Used for Stripe success/cancel URLs and other self-referential links.
APP_URL="https://example.com"

# STRIPE_SECRET_KEY: Your Stripe secret key.
# Use a test key locally and a live key only in production secrets.
STRIPE_SECRET_KEY="sk_test_..."

# STRIPE_PRICE_DUMPSTER_15_RESERVATION: Dashboard-managed Stripe Price ID
# for the 15-yard dumpster reservation deposit.
STRIPE_PRICE_DUMPSTER_15_RESERVATION="price_..."

# STRIPE_WEBHOOK_SECRET: Signing secret for the Stripe webhook endpoint
# that points to /api/stripe/webhook on your deployed site.
STRIPE_WEBHOOK_SECRET="whsec_..."

# BLOB_READ_WRITE_TOKEN: Required on Vercel for durable reservation storage.
# Create a Vercel Blob store and copy its read-write token here.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ADMIN_RESERVATIONS_EMAIL: Login email for the built-in reservation dashboard.
ADMIN_RESERVATIONS_EMAIL="owner@example.com"

# ADMIN_RESERVATIONS_PASSWORD: Password for the built-in reservation dashboard.
# Use a long random value and keep it private.
ADMIN_RESERVATIONS_PASSWORD="replace-with-a-long-random-password"
