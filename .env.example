# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public base URL where this app is hosted.
# Used for Stripe success/cancel URLs and other self-referential links.
APP_URL="https://example.com"

# STRIPE_SECRET_KEY: Your Stripe secret key.
# Use a test key locally and a live key only in production secrets.
STRIPE_SECRET_KEY="sk_test_..."

# STRIPE_PRICE_DUMPSTER_15_RESERVATION: Dashboard-managed Stripe Price ID
# for the 15-yard dumpster reservation deposit.
STRIPE_PRICE_DUMPSTER_15_RESERVATION="price_..."

# STRIPE_WEBHOOK_SECRET: Signing secret for the Stripe webhook endpoint
# that points to /api/stripe/webhook on your deployed site.
STRIPE_WEBHOOK_SECRET="whsec_..."

# NEXT_PUBLIC_GA_ID: Your public GA4 measurement ID used by the site tag.
# Also shown in the admin dashboard to confirm tracking is wired.
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# GA4_PROPERTY_ID: Numeric GA4 property ID used by the admin reporting dashboard.
# This must be the numeric property ID, not the public G- measurement ID.
# Powers the 30-day funnel and traffic reporting in the admin area.
GA4_PROPERTY_ID="123456789"

# GA_SERVICE_ACCOUNT_EMAIL: Service account email with Analytics read access to the GA4 property.
GA_SERVICE_ACCOUNT_EMAIL="analytics-dashboard@example-project.iam.gserviceaccount.com"

# GA_CLIENT_EMAIL: Optional alias for the same service account email.
# Useful if you copy variable names straight from a Google service-account JSON payload.
GA_CLIENT_EMAIL=""

# GA_SERVICE_ACCOUNT_PRIVATE_KEY: Private key for the Analytics service account.
# Keep the embedded \n line breaks exactly as exported by Google.
GA_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# GA_SERVICE_ACCOUNT_JSON: Optional alternative to GA_SERVICE_ACCOUNT_EMAIL and
# GA_SERVICE_ACCOUNT_PRIVATE_KEY. Paste the full one-line service account JSON
# if you prefer storing Google credentials as a single variable in Netlify.
GA_SERVICE_ACCOUNT_JSON=""

# ADMIN_RESERVATIONS_EMAIL: Login email for the built-in business dashboard.
ADMIN_RESERVATIONS_EMAIL="owner@example.com"

# ADMIN_RESERVATIONS_PASSWORD: Password for the built-in business dashboard.
# Use a long random value and keep it private.
ADMIN_RESERVATIONS_PASSWORD="replace-with-a-long-random-password"
